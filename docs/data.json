son": "time", "strategy_version": 2}, {"id": 6, "market": "BTC", "side": "long", "entry": 66232.42258, "exit": 66103.698969, "units": 0.08511137064591161, "pnl": -10.96, "cost": 1.13, "t_in": 1784657700000, "t_out": 1784658600000, "held_min": 15, "exit_reason": "stop", "strategy_version": 2}, {"id": 4, "market": "XAU", "side": "long", "entry": 4075.9241146691893, "exit": 4071.375994474417, "units": 2.4339256410139587, "pnl": -11.07, "cost": 1.09, "t_in": 1784620500000, "t_out": 1784620800000, "held_min": 5, "exit_reason": "stop", "strategy_version": 1}, {"id": 3, "market": "BTC", "side": "long", "entry": 65505.049849999996, "exit": 65464.130262267, "units": 0.15192078956804947, "pnl": -6.22, "cost": 1.99, "t_in": 1784610600000, "t_out": 1784611200000, "held_min": 10, "exit_reason": "stop", "strategy_version": 1}, {"id": 2, "market": "BTC", "side": "long", "entry": 64656.465, "exit": 64593.850248972005, "units": 0.15466357463248262, "pnl": -9.68, "cost": 2.0, "t_in": 1784552700000, "t_out": 1784553600000, "held_min": 15, "exit_reason": "stop", "strategy_version": 1}], "strategy": {"name": "XAU_MeanReversion_RSI_5m_v4", "version": 4, "timeframe": "5m", "markets": ["XAU"], "rationale": "Fade oversold/overbought extremes on XAU during liquid hours. Mean-reversion on 5m has higher WR than breakout-chasing. Cheapest spread. Cron lag less critical - signal persists multiple candles.", "longConditions": [{"indicator": "session", "hours": [7, 17]}, {"indicator": "rsi", "period": 14, "op": "<", "value": 35}, {"indicator": "bollinger", "period": 20, "dev": 2.0, "position": "below_lower"}, {"indicator": "atr_pct", "period": 10, "op": ">", "value": 0.05}, {"indicator": "momentum", "period": 3, "op": ">", "value": 0.0}], "shortConditions": [{"indicator": "session", "hours": [7, 17]}, {"indicator": "rsi", "period": 14, "op": ">", "value": 65}, {"indicator": "bollinger", "period": 20, "dev": 2.0, "position": "above_upper"}, {"indicator": "atr_pct", "period": 10, "op": ">", "value": 0.05}, {"indicator": "momentum", "period": 3, "op": "<", "value": 0.0}], "risk": {"riskPerTradePct": 1.0, "stopLossPct": 0.22, "takeProfitPct": 0.22, "trailingStopPct": 0.1, "maxHoldMinutes": 60.0, "maxOpenPositions": 1, "maxDailyLossPct": 3, "cooldownMinutes": 20.0}}, "history": [{"version": 4, "t": 1784750327684, "analysis": "21% WR with 0.34 PF is catastrophic. Stops hit 14/19 trades. 1m Bollinger breakouts on closed-candle cron lag chase exhausted moves. Spread costs $26 on $81 losses. No edge whatsoever.", "mistakes": ["Chasing 1m breakouts with 5-15min cron lag: by fill time the breakout has already reversed or exhausted - entering at worst possible moment", "stopLossPct 0.18% vs takeProfitPct 0.45% sounds like 2.5R but with 21% WR the math never works: need 65%+ WR at this R:R", "Trading BTC on 1m with $1.95 round-trip cost requires 0.45% TP - but 1m candles rarely sustain 0.45% moves, so time-exits and stops dominate", "ATR compression filter (<0.08%) combined with breakout entry is self-defeating: low ATR means no momentum, breakout quickly snaps back into range"], "changes": ["Switch to 5m candles - reduces cron lag impact, signals stay valid longer, fewer false breakouts", "Use XAU-only or XAU+BTC - ETH excluded (8x spread), BTC used only if conditions very strict", "Mean-reversion logic instead of breakout-chasing: fade extreme RSI after Bollinger touch, not breakout above/through", "Wider SL / tighter TP ratio inverted: use higher WR setups with 1:1 R:R rather than low-WR 1:2.5", "Session filter on XAU: only London/NY overlap 07:00-17:00 UTC to avoid thin-market whipsaws and weekend gap risk"], "tournament": [{"name": "XAU_MeanReversion_RSI_5m_v4", "tf": "5m", "net": 0, "trades": 0, "pf": 0, "winner": true}, {"name": "BTC_SMA_Trend_Pullback_5m_v4", "tf": "5m", "net": -45.54, "trades": 14, "pf": 0.36, "winner": false}, {"name": "XAU_BTC_Breakout_N_Bar_5m_v4", "tf": "5m", "net": -135.97, "trades": 21, "pf": 0.17, "winner": false}], "strategy": {"name": "